# Build context exclusions — keep the image build context small and free of
# host build cruft (the base image builds from the repo root).

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Frontend / build artifacts
node_modules/
dist/
build/

# Version control & secrets
.git/
.gitignore
.env

# OS
.DS_Store
