# LinkShrink environment template — copy to `.env` and fill in real values.
# `.env` is gitignored and must never be committed.

# Short-code generation (hashids) — use a long, random, secret string in real envs.
HASHIDS_SALT=changeme

# PostgreSQL
POSTGRES_USER=linkshrink
POSTGRES_PASSWORD=changeme
POSTGRES_DB=linkshrink
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Public host used for short links and self-reference rejection.
PUBLIC_HOST=link-shrink.org
